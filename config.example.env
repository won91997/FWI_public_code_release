# FWI ten-model benchmark public configuration.
# Copy this file to config.env and edit paths for your machine.

# Project root. This default resolves to the directory containing config.env.
export PIPELINE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export WORK_ROOT="${PIPELINE_ROOT}"

# Dataset root with seismic_full/ and vmodel_full/ subdirectories.
export DATA_ROOT="${DATA_ROOT:-/path/to/DATA_ROOT}"

# Optional: directory containing raw seismic/offset resources used by dataset scripts.
export SEISMIC_DIR="${SEISMIC_DIR:-/path/to/seismic_or_offset_files}"

# Optional: velocity SEG-Y file used when generating the dataset from scratch.
export VELOCITY_SEGY="${VELOCITY_SEGY:-/path/to/velocity.SEGY}"

# Training setup.
export GPU_IDS="${GPU_IDS:-0,1,2,3,4,5,6,7}"
export SEEDS="${SEEDS:-42}"
export BATCH_PER_GPU="${BATCH_PER_GPU:-2}"
export EPOCHS="${EPOCHS:-100}"
export PYTHON_BIN="${PYTHON_BIN:-python3}"

# Optional HuggingFace mirror for ConvNeXt-Kaggle pretrained assets.
export HF_ENDPOINT="${HF_ENDPOINT:-https://hf-mirror.com}"

# Output directories.
export OUT_ROOT_FAIR="${OUT_ROOT_FAIR:-${PIPELINE_ROOT}/logs_fair}"
export OUT_ROOT_NONFAIR="${OUT_ROOT_NONFAIR:-${PIPELINE_ROOT}/logs_nonfair}"

# Split/statistics generated by 02_prepare/run_prepare.sh.
export SPLIT_DIR="${PIPELINE_ROOT}/benchmark/generated_split"
export GLOBAL_MAP="${SPLIT_DIR}/global_map.csv"
export STATS_JSON="${SPLIT_DIR}/train_stats.json"
